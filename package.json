{
  "name": "dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.js --host",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "prod": "npm run build && http-server dist -p 8181",
    "re-link": "npm rm bindrjs && sudo npm link ../../bindrjs",
    "link": "npm run re-link && npm run dev",
    "deploy": "git pull && npm run build && sudo systemctl restart homehub-dashboard.service"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "http-server": "^14.1.1",
    "sass": "^1.54.9",
    "typescript": "^4.6.4",
    "vite": "^3.1.0"
  },
  "dependencies": {
    "bindrjs": "1.5.0",
    "hls.js": "^1.6.16",
    "iconoir": "^6.7.0",
    "socket.io-client": "^4.5.2"
  }
}
